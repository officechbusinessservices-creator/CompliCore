{
  "name": "rental-backend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc -p .",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "seed": "ts-node prisma/seed.ts",
    "test": "ENABLE_DEMO_FALLBACK=true vitest --run --config vitest.config.mts"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.997.0",
    "@fastify/compress": "^7.0.0",
    "@fastify/cookie": "^8.3.0",
    "@fastify/cors": "^8.5.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^6.0.0",
    "@fastify/middie": "^9.2.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.8.0",
    "@simplewebauthn/server": "^13.2.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "cloudinary": "^2.7.0",
    "dotenv": "^16.0.0",
    "fastify": "^5.7.3",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.9.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.0",
    "pg-query-stream": "^4.12.0",
    "prom-client": "^15.1.3",
    "redis": "^5.10.0",
    "socket.io": "^4.8.3",
    "zod": "^3.23.8",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0"
  },
  "devDependencies": {
    "prisma": "^5.8.0",
    "ts-node-dev": "^2.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "typescript": "^5.3.0",
    "vitest": "^3.0.0"
  }
}
