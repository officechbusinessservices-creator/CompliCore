# ── Complicore Production Environment ──────────────────────
# Copy to .env.prod and fill in before deploying

# ── Database ───────────────────────────────────────────────
# Render provides this automatically via managed Postgres
# DATABASE_URL=postgresql://user:pass@host:5432/complicore

# ── Redis ──────────────────────────────────────────────────
# Render provides this automatically via managed Redis
# REDIS_URL=redis://host:6379

# ── Temporal Cloud ─────────────────────────────────────────
# Sign up at https://temporal.io and create a namespace
TEMPORAL_HOST=your-namespace.tmprl.cloud:7233
TEMPORAL_NAMESPACE=complicore-prod
TEMPORAL_CLIENT_CERT_PATH=/etc/temporal/cert.pem
TEMPORAL_CLIENT_KEY_PATH=/etc/temporal/key.pem

# ── LLM Providers ──────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# ── NextAuth ───────────────────────────────────────────────
# Render auto-generates NEXTAUTH_SECRET
NEXTAUTH_SECRET=render-auto-generates-this
NEXTAUTH_URL=https://complicore-web.onrender.com

# ── API ────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=https://complicore-api.onrender.com

# ── Security ───────────────────────────────────────────────
# Set to true in production
COOKIE_SECURE=true
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Worker ─────────────────────────────────────────────────
WORKER_ROLES=orchestrator
WORKER_MAX_CONCURRENCY=8
WORKER_HEARTBEAT_INTERVAL_S=15

# ── Monitoring ─────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-password
ALERTMANAGER_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
ALERTMANAGER_SLACK_CHANNEL=#complicore-alerts

# ── Misc ───────────────────────────────────────────────────
TZ=America/New_York
NODE_ENV=production
